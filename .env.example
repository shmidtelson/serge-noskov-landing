# Ссылка на канал Max (кнопки «Подписаться»). Публичные переменные Astro — с префиксом PUBLIC_.
PUBLIC_MAX_CHANNEL_URL=https://max.ru/your-channel

# Яндекс.Метрика: номер счётчика и идентификаторы JavaScript-целей (как в настройках счётчика → Цели).
# По умолчанию цели max_subscribe / vk_subscribe — создайте их в Метрике или переименуйте здесь.
PUBLIC_YM_COUNTER_ID=108753895
PUBLIC_YM_GOAL_MAX=max_subscribe
PUBLIC_YM_GOAL_VK=vk_subscribe

# Фото: по умолчанию public/landing/autor.png (в HTML подставляется base для GitHub Pages).
# Другой файл — путь внутри public, без ведущего /:
# PUBLIC_LANDING_AUTHOR_IMAGE=landing/другое.png

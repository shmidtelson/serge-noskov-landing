---
import Base from '../../layouts/Base.astro';
import { LANDING_THEMES, type LandingVariant } from '../../lib/landingThemes';
import '../../styles/global.css';

const base = import.meta.env.BASE_URL;
const entries: { href: string; id: LandingVariant }[] = [
  { href: base, id: 'classic' },
  { href: `${base}midnight/`, id: 'midnight' },
  { href: `${base}nordic/`, id: 'nordic' },
  { href: `${base}editorial/`, id: 'editorial' },
  { href: `${base}aurora/`, id: 'aurora' },
];
---

<Base
  title="Варианты оформления лендинга"
  description="Пять визуальных концепций для выбора основного дизайна."
>
  <div class="min-h-screen bg-stone-100 px-4 py-12 sm:px-6">
    <div class="mx-auto max-w-3xl">
      <p class="text-sm font-medium uppercase tracking-wider text-stone-500">Для Сергея</p>
      <h1 class="mt-2 font-serif text-3xl font-semibold text-stone-900 sm:text-4xl">Сравнение вариантов</h1>
      <p class="mt-4 text-lg text-stone-600">
        Откройте каждую карточку в новой вкладке. Главная страница репозитория — первая тема («Тёплая»); остальные — отдельные
        пути.
      </p>
      <ul class="mt-10 space-y-4">
        {
          entries.map(({ href, id }) => {
            const t = LANDING_THEMES[id];
            return (
              <li>
                <a
                  href={href}
                  class="block rounded-2xl border border-stone-200 bg-white p-5 shadow-sm transition hover:border-stone-300 hover:shadow-md"
                >
                  <span class="text-xs font-semibold uppercase tracking-wide text-stone-400">{id}</span>
                  <span class="mt-1 block font-serif text-xl font-semibold text-stone-900">{t.label}</span>
                  <span class="mt-2 block text-stone-600">{t.blurb}</span>
                  <span class="mt-3 inline-block text-sm font-medium text-indigo-600">Открыть →</span>
                </a>
              </li>
            );
          })
        }
      </ul>
    </div>
  </div>
</Base>

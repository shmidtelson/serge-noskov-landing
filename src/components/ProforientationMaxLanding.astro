---
import type { LandingVariant } from '../lib/landingThemes';
import { LANDING_THEMES } from '../lib/landingThemes';
import { painItems, channelItems } from '../data/landingContent';
import MaxLogoIcon from './icons/MaxLogoIcon.astro';
import VkLogoIcon from './icons/VkLogoIcon.astro';

export interface Props {
  maxChannelUrl: string;
  vkChannelUrl: string;
  authorImageSrc?: string;
  variant?: LandingVariant;
}
const { maxChannelUrl, vkChannelUrl, authorImageSrc, variant = 'aurora' } = Astro.props;
const t = LANDING_THEMES[variant];
/** Идентификаторы целей в Метрике — создайте цели с такими ID или задайте PUBLIC_YM_GOAL_* в .env */
const ymGoalMax = import.meta.env.PUBLIC_YM_GOAL_MAX?.trim() || 'max_subscribe';
const ymGoalVk = import.meta.env.PUBLIC_YM_GOAL_VK?.trim() || 'vk_subscribe';
---

<div class={t.page}>
  <div class={t.bg1} style={t.bg1Style || undefined}></div>
  <div class={t.bg2} style={t.bg2Style}></div>

  <section class="relative mx-auto max-w-6xl px-4 pb-20 pt-12 sm:px-6 sm:pb-24 sm:pt-16 lg:pt-20">
    <div class="grid items-center gap-10 lg:grid-cols-2 lg:gap-16">
      <div>
        <p class={t.kicker}>Профориентация и воспитание</p>
        <h1 class:list={['mt-3', t.h1]}>Сергей Носков</h1>
        <p class:list={['mt-6', t.lead]}>
          <strong class="font-semibold text-slate-900">
            Помогаю подросткам выбрать профессию, а взрослым — сменить карьеру без потери дохода
          </strong>
          <br />
          <span class="inline-block mt-3">
            Педагог-практик с 20-летним стажем. Без абстрактных советов — только пошаговые стратегии. Помогаю наладить
            диалог в семье и превратить конфликт поколений в точку роста.
          </span>
        </p>
        <div class="mt-8 grid gap-3 sm:grid-cols-3">
          <div class="rounded-2xl border border-white/60 bg-white/70 px-4 py-3 text-center shadow-sm backdrop-blur">
            <p class="text-lg font-bold text-slate-900">🗣️ 1000+</p>
            <p class="text-sm text-slate-600">консультаций</p>
            <p class="mt-1 text-xs text-slate-500">реальных кейсов с 2018 г.</p>
          </div>
          <div class="rounded-2xl border border-white/60 bg-white/70 px-4 py-3 text-center shadow-sm backdrop-blur">
            <p class="text-lg font-bold text-slate-900">🎓 90%+</p>
            <p class="text-sm text-slate-600">поступили на бюджет</p>
            <p class="mt-1 text-xs text-slate-500">сопровождение до результата</p>
          </div>
          <div class="rounded-2xl border border-white/60 bg-white/70 px-4 py-3 text-center shadow-sm backdrop-blur">
            <p class="text-lg font-bold text-slate-900">💼 250+</p>
            <p class="text-sm text-slate-600">карьерных переходов</p>
            <p class="mt-1 text-xs text-slate-500">без потери дохода</p>
          </div>
        </div>
        <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:items-center">
          <a href={maxChannelUrl} target="_blank" rel="noopener noreferrer" class={t.cta} data-ym-goal={ymGoalMax}>
            Подписаться
            <MaxLogoIcon class="h-5 w-5 shrink-0" />
          </a>
          <a href={vkChannelUrl} target="_blank" rel="noopener noreferrer" class={t.cta} data-ym-goal={ymGoalVk}>
            Подписаться
            <VkLogoIcon class="h-5 w-5 shrink-0" />
          </a>
        </div>
      </div>

      <div class="relative mx-auto w-full max-w-md lg:max-w-none">
        <div class={t.imageFrame}>
          {
            authorImageSrc ? (
              <img
                src={authorImageSrc}
                alt="Сергей Носков"
                class="absolute inset-0 h-full w-full object-cover object-top"
                width="800"
                height="1000"
                fetchpriority="high"
              />
            ) : (
              <div class={t.emptyPhoto}>
                <div class="mb-4 flex h-24 w-24 items-center justify-center rounded-full border-2 border-current/20 text-3xl font-semibold backdrop-blur-sm">
                  СН
                </div>
                <p class:list={['text-sm font-medium', t.placeholder]}>Фото автора</p>
                <p class:list={['mt-1 max-w-xs text-xs leading-relaxed', t.painText]}>
                  Добавьте <code class="rounded bg-black/10 px-1 dark:bg-white/10">public/landing/autor.png</code> или
                  <code class="rounded bg-black/10 px-1 dark:bg-white/10">PUBLIC_LANDING_AUTHOR_IMAGE</code> в .env
                </p>
              </div>
            )
          }
        </div>
        <div class:list={['pointer-events-none', t.deco]} aria-hidden="true" />
      </div>
    </div>
  </section>

  <section class={t.painSection}>
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <h2 class:list={[t.h2, t.painTitle]}>Знакомо?</h2>
      <ul class="mt-10 grid gap-4 sm:grid-cols-2">
        {
          painItems.map((text) => (
            <li class={t.painCard}>
              <span class={t.painIcon}>▹</span>
              <span class={t.painText}>{text}</span>
            </li>
          ))
        }
      </ul>
      <p class={t.bridge}>
        В канале Max я показываю, как превратить сомнения в понятный пошаговый план. Без воды, только рабочие алгоритмы.
      </p>
      <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:items-center">
        <a href={maxChannelUrl} target="_blank" rel="noopener noreferrer" class={t.cta} data-ym-goal={ymGoalMax}>
          Подписаться
          <MaxLogoIcon class="h-5 w-5 shrink-0" />
        </a>
        <a href={vkChannelUrl} target="_blank" rel="noopener noreferrer" class={t.cta} data-ym-goal={ymGoalVk}>
          Подписаться
          <VkLogoIcon class="h-5 w-5 shrink-0" />
        </a>
      </div>
    </div>
  </section>

  <section class="relative py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <h2 class:list={[t.h2, t.trustTitle]}>Почему мне можно доверять?</h2>
      <div class="mt-10 space-y-5">
        <div class={t.row}>
          <span class={t.iconBox}>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.75"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="h-6 w-6"
              aria-hidden="true"
            >
              <path d="M21.42 10.922a1 1 0 0 0-.019-1.838L12.83 5.18a2 2 0 0 0-1.66 0L2.6 9.08a1 1 0 0 0 0 1.832l8.57 3.908a2 2 0 0 0 1.66 0z" />
              <path d="M22 10v6" />
              <path d="M6 12.5V16a6 3 0 0 0 12 0v-3.5" />
            </svg>
          </span>
          <p class={t.rowText}>Кандидат наук, доцент, педагог-профориентолог с опытом 20+ лет</p>
        </div>
        <div class={t.row}>
          <span class={t.iconBox}>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.75"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="h-6 w-6"
              aria-hidden="true"
            >
              <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" />
              <path d="M16 3.128a4 4 0 0 1 0 7.744" />
              <path d="M22 21v-2a4 4 0 0 0-3-3.87" />
              <circle cx="9" cy="7" r="4" />
            </svg>
          </span>
          <p class={t.rowText}>
            Многодетный отец и предприниматель: понимаю семейный контекст и реальные требования рынка труда
          </p>
        </div>
        <div class={t.row}>
          <span class={t.iconBox}>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.75"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="h-6 w-6"
              aria-hidden="true"
            >
              <path d="M2.586 17.414A2 2 0 0 0 2 18.828V21a1 1 0 0 0 1 1h3a1 1 0 0 0 1-1v-1a1 1 0 0 1 1-1h1a1 1 0 0 0 1-1v-1a1 1 0 0 1 1-1h.172a2 2 0 0 0 1.414-.586l.814-.814a6.5 6.5 0 1 0-4-4z" />
              <circle cx="16.5" cy="7.5" r=".5" fill="currentColor" />
            </svg>
          </span>
          <p class={t.rowText}>
            Главное отличие: теория всегда переплетена с практикой. Никаких абстрактных тестов — только кейсы, разборы
            ошибок и стратегии, которые можно применить завтра.
          </p>
        </div>
      </div>

      <div class={t.listBox}>
        <p class:list={['flex items-center gap-2', t.listKicker]}>
          <span aria-hidden="true">📦</span> Внутри канала
        </p>
        <ul class="mt-6 space-y-3">
          {
            channelItems.map((line) => (
              <li class={t.listText}>
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="24"
                  height="24"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class={t.check}
                  aria-hidden="true"
                >
                  <path d="M20 6 9 17l-5-5" />
                </svg>
                <span class="leading-relaxed">{line}</span>
              </li>
            ))
          }
        </ul>
      </div>

      <div class="mt-10 flex flex-col gap-3 sm:flex-row sm:items-center">
        <a href={maxChannelUrl} target="_blank" rel="noopener noreferrer" class={t.cta} data-ym-goal={ymGoalMax}>
          Подписаться
          <MaxLogoIcon class="h-5 w-5 shrink-0" />
        </a>
        <a href={vkChannelUrl} target="_blank" rel="noopener noreferrer" class={t.cta} data-ym-goal={ymGoalVk}>
          Подписаться
          <VkLogoIcon class="h-5 w-5 shrink-0" />
        </a>
      </div>
    </div>
  </section>

  <section class={t.finalSection}>
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6">
      <h2 class={t.finalH}>Разбираемся вместе. Не принимайте решения вслепую.</h2>
      <p class:list={['mt-6', t.finalP]}>
        Присоединяйтесь к сообществу родителей и взрослых, которые выбирают осознанно. Новые материалы выходят
        регулярно. Отписаться можно в любой момент.
      </p>
      <div class="mt-10 flex flex-col items-center gap-3 sm:flex-row sm:justify-center">
        <a href={maxChannelUrl} target="_blank" rel="noopener noreferrer" class={t.finalCta} data-ym-goal={ymGoalMax}>
          Подписаться
          <MaxLogoIcon class="h-5 w-5 shrink-0" />
        </a>
        <a href={vkChannelUrl} target="_blank" rel="noopener noreferrer" class={t.finalCta} data-ym-goal={ymGoalVk}>
          Подписаться
          <VkLogoIcon variant="onLight" class="h-5 w-5 shrink-0" />
        </a>
        <p class:list={[t.finalNote]}>Канал бесплатный. Никакого спама.</p>
      </div>
    </div>
  </section>
</div>

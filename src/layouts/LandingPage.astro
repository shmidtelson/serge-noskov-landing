---
import Base from './Base.astro';
import ProforientationMaxLanding from '../components/ProforientationMaxLanding.astro';
import { LANDING_THEMES } from '../lib/landingThemes';
import { publicUrl } from '../lib/sitePaths';
import { DEFAULT_AUTHOR_REL } from '../data/landingContent';
import '../styles/global.css';

const variant = 'aurora';

const maxUrl = import.meta.env.PUBLIC_MAX_CHANNEL_URL || 'https://max.ru/id550601110275_biz';
const vkUrl = import.meta.env.PUBLIC_VK_CHANNEL_URL || 'https://vk.com/education_career';
const base = import.meta.env.BASE_URL;
const authorFromEnv = import.meta.env.PUBLIC_LANDING_AUTHOR_IMAGE?.trim();
const authorImage =
  authorFromEnv && authorFromEnv.length > 0
    ? publicUrl(authorFromEnv, base)
    : publicUrl(DEFAULT_AUTHOR_REL, base);

const theme = LANDING_THEMES[variant];
const title = `Профориентация — Сергей Носков | ${theme.label}`;
const description =
  'Сергей Носков — педагог, кандидат наук. Бесплатный канал Max: профориентация и смена карьеры.';
---

<Base title={title} description={description}>
  <ProforientationMaxLanding
    maxChannelUrl={maxUrl}
    vkChannelUrl={vkUrl}
    authorImageSrc={authorImage}
    variant={variant}
  />
</Base>
